{
  "version": 2,
  "rewrites": [
    { "source": "/assets/(.*)", "destination": "/dist/client/assets/$1" },
    { "source": "/images/(.*)", "destination": "/dist/client/images/$1" },
    { "source": "/favicon.ico", "destination": "/dist/client/favicon.ico" },
    { "source": "/logo.png", "destination": "/dist/client/logo.png" },
    { "source": "/(.*)", "destination": "/api/index.js" }
  ]
}
